{
  "root": true,
  "parser": "@typescript-eslint/parser",
  "plugins": ["@typescript-eslint"],
  "rules": {
    "@typescript-eslint/no-var-requires": "error",
    "no-unused-vars": "off"
  },
  "overrides": [
    {
      "files": ["**/*.test.ts"],
      "rules": {
        "no-unused-vars": "off"
      }
    }
  ],
  "env": {
    "es2022": true,
    "node": true
  }
}