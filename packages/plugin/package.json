{
  "name": "@openclaw/ai-spaces",
  "version": "0.1.0",
  "description": "Share portions of your AI agent's workspace with collaborators",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "scripts": {
    "lint": "eslint 'src/**/*.ts' --max-warnings 0",
    "build": "npm run lint && tsc && node scripts/bundle-web.mjs",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "setupEntry": "./dist/setup-entry.js"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "spaces",
    "collaboration"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jchadwick/ai-spaces.git"
  },
  "bugs": {
    "url": "https://github.com/jchadwick/ai-spaces/issues"
  },
  "homepage": "https://github.com/jchadwick/ai-spaces#readme",
  "dependencies": {
    "@ai-spaces/shared": "*",
    "@types/jsonwebtoken": "^9.0.10",
    "bcrypt": "^6.0.0",
    "jsonwebtoken": "^9.0.3",
    "mime-types": "^3.0.2",
    "openclaw": "^2026.3.28",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "esbuild": "^0.27.4",
    "eslint": "^8.57.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
