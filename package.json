{
  "name": "ai-spaces",
  "version": "0.1.0",
  "private": true,
  "description": "Share portions of your AI agent's workspace with collaborators",
  "keywords": [
    "openclaw",
    "plugin",
    "spaces",
    "collaboration"
  ],
  "author": "Jess Chadwick <jesschadwick@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jchadwick/ai-spaces.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run typecheck && npm run build:shared && npm run build:core && npm run build:plugin",
    "build:core": "npm run build:web & npm run build:server & wait",
    "build:shared": "npm run build -w @ai-spaces/shared",
    "build:web": "npm run build -w @ai-spaces/web",
    "build:plugin": "npm run build -w @openclaw/ai-spaces",
    "build:server": "npm run build -w @ai-spaces/server",
    "dev:web": "npm run dev -w @ai-spaces/web",
    "dev:server": "npm run dev -w @ai-spaces/server",
    "dev:plugin": "npm run dev -w @openclaw/ai-spaces",
    "typecheck": "npm run typecheck -w @ai-spaces/shared -w @ai-spaces/web -w @ai-spaces/server -w @openclaw/ai-spaces",
    "test": "npm run test -ws --if-present",
    "test:e2e": "playwright test",
    "test:e2e:api": "playwright test --project=api",
    "test:e2e:ui": "playwright test --project=ui",
    "test:e2e:install": "playwright install chromium",
    "lint": "biome lint --write",
    "lint:check": "biome lint",
    "format": "biome format --write",
    "format:check": "biome format",
    "check": "biome check --write",
    "check:ci": "biome check",
    "prepare": "husky",
    "verify": "npm run check"
  },
  "dependencies": {
    "@lexical/table": "^0.43.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@playwright/test": "^1.49.1",
    "@typescript/native-preview": "^7.0.0-dev.20260509.2",
    "husky": "^9.1.7",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "ws": "^8.18.0"
  }
}
