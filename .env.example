# =============================================================================
# AI Spaces — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the required values.
# Lines marked "Required" MUST be set. Lines marked "Dev default" are safe
# to leave unchanged for local development.
# =============================================================================


# =============================================================================
# SECRETS — Required; change in production
# =============================================================================

# JWT signing secret for access tokens.
# Required — use a long random string in production.
JWT_SECRET=ai-spaces-dev-secret-change-in-production

# JWT signing secret for refresh tokens.
# Required — use a different long random string in production.
JWT_REFRESH_SECRET=ai-spaces-refresh-secret-change-in-production

# Shared bearer token between the server and the OpenClaw gateway.
# Required — change in production.
GATEWAY_TOKEN=secret

# Groq API key for AI model access.
# Required in production; optional during local dev (features will be limited).
# GROQ_API_KEY=


# =============================================================================
# OpenClaw / Plugin variables
# =============================================================================

# Path to the OpenClaw home directory (stores agent config and state).
# Required — no default; must be set explicitly.
OPENCLAW_HOME=/home/openclaw

# Path to the compiled plugin entry point loaded by OpenClaw.
# Dev default — adjust if your plugin dist is in a different location.
PLUGIN_DIST=./packages/plugin/dist/index.js

# Port the OpenClaw gateway listens on.
# Dev default — ok to leave as-is.
OPENCLAW_GATEWAY_PORT=19000

# Disable Bonjour/mDNS discovery (recommended for server environments).
# Dev default — ok to leave as-is.
OPENCLAW_DISABLE_BONJOUR=1

# Comma-separated list of tool categories denied by default for agents.
# Dev default — see plugin/src/config.ts for available categories.
# AI_SPACES_DENIED_TOOLS=exec,messaging,spawn_agents,browser,credentials

# Comma-separated list of tool categories allowed by default for agents.
# Dev default — see plugin/src/config.ts for available categories.
# AI_SPACES_ALLOWED_TOOLS=read,write,edit,glob


# =============================================================================
# Server variables
# =============================================================================

# Port the AI Spaces HTTP server listens on.
# Dev default — ok to leave as-is.
AI_SPACES_PORT=3001

# URL to the OpenClaw gateway (used by the server to dispatch agent requests).
# Dev default for local; override for Docker/production.
GATEWAY_URL=http://localhost:19000

# WebSocket URL of the plugin's dedicated WS server (bypasses gateway control protocol).
# Dev default for local; override for Docker/production.
PLUGIN_WS_URL=ws://127.0.0.1:3002

# URL the plugin uses to reach the AI Spaces server (used inside the agent runtime).
# Dev default for local; override for Docker/production.
AI_SPACES_URL=http://127.0.0.1:3001

# WebSocket port the plugin exposes for direct server↔plugin communication.
# Dev default — must match PLUGIN_WS_URL port above.
AI_SPACES_WS_PORT=3002


# =============================================================================
# Shared / file-system variables
# =============================================================================

# Root directory where AI Spaces stores user workspaces (spaces/files).
# Dev default — override to a dedicated volume path in production.
AI_SPACES_ROOT=${HOME}/ai-spaces-workspace

# Directory for AI Spaces application data (database, etc.).
# Dev default — defaults to ${HOME}/.ai-spaces if unset.
# AI_SPACES_DATA=

# Path to the SQLite database file.
# Dev default — defaults to ${AI_SPACES_DATA}/ai-spaces.db if unset.
# AI_SPACES_DB=

# Path to the built web app dist directory served by the server.
# Dev default — adjust if your web package is built elsewhere.
# WEB_DIST=${HOME}/ai-spaces/packages/web/dist
